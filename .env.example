# API key used to authenticate requests to the email service provider
# Keep this value secret and never commit it to version control
RESEND_API_KEY="key"

# Default sender name and email address used for outgoing emails
# In production, this should use a verified domain (e.g. no-reply@yourdomain.com)
FROM_EMAIL="Dev <onboarding@resend.dev>"

# Address of the message broker used for background job processing
# Format: host:port
#
# When running the application outside Docker (locally),
# use: BROKER_ADDR=localhost:6379
#
# When running inside Docker Compose, DO NOT use localhost.
# Inside a container, localhost refers to the container itself.
# Instead, use the service name defined in docker-compose.yml.
# Example:
# BROKER_ADDR=redis:6379
#
# In production, use a secure and non-publicly exposed Redis endpoint.
BROKER_ADDR=redis:6379 or localhost:6379
